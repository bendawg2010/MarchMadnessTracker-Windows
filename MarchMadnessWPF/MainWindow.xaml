<Window x:Class="MarchMadnessTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:MarchMadnessTracker.Views"
        Title="March Madness Tracker"
        Width="420" Height="650"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource DarkWindowStyle}"
        ResizeMode="CanResize"
        MinWidth="380" MinHeight="500">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource DarkSurfaceBrush}"
                Padding="16,12" CornerRadius="0,0,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Basketball Icon -->
                <TextBlock Grid.Column="0" Text="&#x1F3C0;"
                           FontSize="24" VerticalAlignment="Center"
                           Margin="0,0,10,0" />

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="March Madness"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Text="{Binding StatusText}"
                               FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>

                <!-- Loading indicator -->
                <TextBlock Grid.Column="2" Text="..."
                           FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}"
                           VerticalAlignment="Center"
                           Visibility="{Binding IsLoading, Converter={StaticResource BoolVis}}" />
            </Grid>
        </Border>

        <!-- Tab Content -->
        <TabControl Grid.Row="1"
                     Style="{StaticResource DarkTabControl}"
                     SelectedIndex="{Binding SelectedTabIndex}"
                     Background="{StaticResource DarkBgBrush}">

            <TabItem Header="&#x1F3C0; Scores" Style="{StaticResource DarkTabItem}">
                <views:ScoresView DataContext="{Binding ScoresVM}" />
            </TabItem>

            <TabItem Header="&#x1F3C6; Bracket" Style="{StaticResource DarkTabItem}">
                <views:BracketView DataContext="{Binding BracketVM}" />
            </TabItem>

            <TabItem Header="&#x1F4C5; Schedule" Style="{StaticResource DarkTabItem}">
                <views:ScheduleView DataContext="{Binding ScheduleVM}" />
            </TabItem>

            <TabItem Header="&#x2699; Settings" Style="{StaticResource DarkTabItem}">
                <views:SettingsView DataContext="{Binding SettingsVM}" />
            </TabItem>
        </TabControl>

        <!-- Bottom Bar -->
        <Border Grid.Row="2" Background="{StaticResource DarkSurfaceBrush}"
                Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="NCAA Tournament 2026"
                           FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center" />

                <Button Grid.Column="1"
                        Content="Quit"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding QuitCommand}"
                        Padding="12,6"
                        FontSize="11" />
            </Grid>
        </Border>
    </Grid>
</Window>
