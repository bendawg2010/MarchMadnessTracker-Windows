<UserControl x:Class="MarchMadnessTracker.Views.ScoresView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:MarchMadnessTracker.Converters"
             Background="{StaticResource DarkBgBrush}">

    <Grid Margin="12,8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Search Box -->
        <TextBox Grid.Row="0"
                 Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                 Style="{StaticResource DarkTextBox}"
                 Margin="0,4,0,8">
            <TextBox.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="6" />
                </Style>
            </TextBox.Resources>
        </TextBox>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Live Games Section -->
                <StackPanel Visibility="{Binding LiveGames.Count, Converter={StaticResource CountToVis}}">
                    <Grid Margin="0,4,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Ellipse Width="8" Height="8" Fill="{StaticResource LiveGreenBrush}"
                                 VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Grid.Column="1" Text="LIVE GAMES"
                                   Style="{StaticResource SectionHeader}" Margin="0" />
                    </Grid>

                    <ItemsControl ItemsSource="{Binding LiveGames}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource GameCard}"
                                        BorderBrush="{Binding IsUpset, Converter={StaticResource UpsetToBorder}}"
                                        BorderThickness="1"
                                        MouseLeftButtonUp="GameCard_Click">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <!-- Status Bar -->
                                        <Grid Grid.Row="0" Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal">
                                                <Border Background="{StaticResource LiveGreenBrush}"
                                                        CornerRadius="3" Padding="6,2">
                                                    <TextBlock Text="LIVE" FontSize="10"
                                                               FontWeight="Bold" Foreground="White" />
                                                </Border>
                                                <TextBlock Text="{Binding TimeDisplay}"
                                                           FontSize="11" Margin="8,0,0,0"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding Broadcast}"
                                                       FontSize="10"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       VerticalAlignment="Center" />
                                        </Grid>

                                        <!-- Away Team -->
                                        <Grid Grid.Row="1" Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0"
                                                    Background="{Binding AwayColor, Converter={StaticResource HexToColor}}"
                                                    CornerRadius="4" Padding="6,2" Margin="0,0,8,0"
                                                    Visibility="{Binding AwaySeed, Converter={StaticResource SeedToVis}}">
                                                <TextBlock Text="{Binding AwaySeed}" FontSize="11"
                                                           FontWeight="Bold" Foreground="White" />
                                            </Border>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding AwayTeam}"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding AwayScore}"
                                                       FontSize="20" FontWeight="Bold"
                                                       Foreground="{StaticResource TextPrimaryBrush}" />
                                        </Grid>

                                        <!-- Home Team -->
                                        <Grid Grid.Row="2" Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0"
                                                    Background="{Binding HomeColor, Converter={StaticResource HexToColor}}"
                                                    CornerRadius="4" Padding="6,2" Margin="0,0,8,0"
                                                    Visibility="{Binding HomeSeed, Converter={StaticResource SeedToVis}}">
                                                <TextBlock Text="{Binding HomeSeed}" FontSize="11"
                                                           FontWeight="Bold" Foreground="White" />
                                            </Border>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding HomeTeam}"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding HomeScore}"
                                                       FontSize="20" FontWeight="Bold"
                                                       Foreground="{StaticResource TextPrimaryBrush}" />
                                        </Grid>

                                        <!-- Upset Indicator -->
                                        <Border Grid.Row="0" HorizontalAlignment="Right"
                                                Visibility="{Binding IsUpset, Converter={StaticResource BoolToVis}}"
                                                Margin="0,0,60,0">
                                            <Border Background="{StaticResource UpsetOrangeBrush}"
                                                    CornerRadius="3" Padding="6,2">
                                                <TextBlock Text="UPSET" FontSize="9"
                                                           FontWeight="Bold" Foreground="White" />
                                            </Border>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Completed Games Section -->
                <StackPanel Visibility="{Binding CompletedGames.Count, Converter={StaticResource CountToVis}}">
                    <TextBlock Text="COMPLETED" Style="{StaticResource SectionHeader}" />
                    <ItemsControl ItemsSource="{Binding CompletedGames}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource GameCard}"
                                        BorderBrush="{Binding IsUpset, Converter={StaticResource UpsetToBorder}}"
                                        BorderThickness="1"
                                        Opacity="0.85"
                                        MouseLeftButtonUp="GameCard_Click">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0" Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal">
                                                <Border Background="#9E9E9E"
                                                        CornerRadius="3" Padding="6,2">
                                                    <TextBlock Text="FINAL" FontSize="10"
                                                               FontWeight="Bold" Foreground="White" />
                                                </Border>
                                                <TextBlock Text="{Binding RoundInfo}"
                                                           FontSize="10" Margin="8,0,0,0"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                            <Border Grid.Column="1"
                                                    Visibility="{Binding IsUpset, Converter={StaticResource BoolToVis}}"
                                                    Background="{StaticResource UpsetOrangeBrush}"
                                                    CornerRadius="3" Padding="6,2">
                                                <TextBlock Text="UPSET" FontSize="9"
                                                           FontWeight="Bold" Foreground="White" />
                                            </Border>
                                        </Grid>

                                        <Grid Grid.Row="1" Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0"
                                                    Background="{Binding AwayColor, Converter={StaticResource HexToColor}}"
                                                    CornerRadius="4" Padding="6,2" Margin="0,0,8,0"
                                                    Visibility="{Binding AwaySeed, Converter={StaticResource SeedToVis}}">
                                                <TextBlock Text="{Binding AwaySeed}" FontSize="11"
                                                           FontWeight="Bold" Foreground="White" />
                                            </Border>
                                            <TextBlock Grid.Column="1" Text="{Binding AwayTeam}"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2" Text="{Binding AwayScore}"
                                                       FontSize="20" FontWeight="Bold"
                                                       Foreground="{StaticResource TextPrimaryBrush}" />
                                        </Grid>

                                        <Grid Grid.Row="2" Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0"
                                                    Background="{Binding HomeColor, Converter={StaticResource HexToColor}}"
                                                    CornerRadius="4" Padding="6,2" Margin="0,0,8,0"
                                                    Visibility="{Binding HomeSeed, Converter={StaticResource SeedToVis}}">
                                                <TextBlock Text="{Binding HomeSeed}" FontSize="11"
                                                           FontWeight="Bold" Foreground="White" />
                                            </Border>
                                            <TextBlock Grid.Column="1" Text="{Binding HomeTeam}"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2" Text="{Binding HomeScore}"
                                                       FontSize="20" FontWeight="Bold"
                                                       Foreground="{StaticResource TextPrimaryBrush}" />
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Upcoming Games Section -->
                <StackPanel Visibility="{Binding UpcomingGames.Count, Converter={StaticResource CountToVis}}">
                    <TextBlock Text="UPCOMING" Style="{StaticResource SectionHeader}" />
                    <ItemsControl ItemsSource="{Binding UpcomingGames}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource GameCard}"
                                        BorderBrush="{StaticResource DarkCardBrush}"
                                        BorderThickness="1"
                                        Opacity="0.75"
                                        MouseLeftButtonUp="GameCard_Click">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0" Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal">
                                                <Border Background="#64B5F6"
                                                        CornerRadius="3" Padding="6,2">
                                                    <TextBlock Text="{Binding TimeDisplay}" FontSize="10"
                                                               FontWeight="Bold" Foreground="White" />
                                                </Border>
                                                <TextBlock Text="{Binding RoundInfo}"
                                                           FontSize="10" Margin="8,0,0,0"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding Broadcast}"
                                                       FontSize="10"
                                                       Foreground="{StaticResource TextSecondaryBrush}" />
                                        </Grid>

                                        <Grid Grid.Row="1" Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0"
                                                    Background="{Binding AwayColor, Converter={StaticResource HexToColor}}"
                                                    CornerRadius="4" Padding="6,2" Margin="0,0,8,0"
                                                    Visibility="{Binding AwaySeed, Converter={StaticResource SeedToVis}}">
                                                <TextBlock Text="{Binding AwaySeed}" FontSize="11"
                                                           FontWeight="Bold" Foreground="White" />
                                            </Border>
                                            <TextBlock Grid.Column="1" Text="{Binding AwayTeam}"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}" />
                                        </Grid>

                                        <Grid Grid.Row="2" Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0"
                                                    Background="{Binding HomeColor, Converter={StaticResource HexToColor}}"
                                                    CornerRadius="4" Padding="6,2" Margin="0,0,8,0"
                                                    Visibility="{Binding HomeSeed, Converter={StaticResource SeedToVis}}">
                                                <TextBlock Text="{Binding HomeSeed}" FontSize="11"
                                                           FontWeight="Bold" Foreground="White" />
                                            </Border>
                                            <TextBlock Grid.Column="1" Text="{Binding HomeTeam}"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}" />
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- No Games Message -->
                <TextBlock Text="No games found. Check back during tournament time!"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="14" TextAlignment="Center"
                           Margin="0,40,0,0"
                           HorizontalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding LiveGames.Count}" Value="0" />
                                        <Condition Binding="{Binding CompletedGames.Count}" Value="0" />
                                        <Condition Binding="{Binding UpcomingGames.Count}" Value="0" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
