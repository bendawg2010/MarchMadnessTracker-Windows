<Window x:Class="MarchMadnessTracker.Views.FloatingScoreWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Score Widget"
        Width="280" Height="120"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border Background="#E6161B2E" CornerRadius="12"
            BorderBrush="{StaticResource DarkCardBrush}"
            BorderThickness="1"
            Padding="12,10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Status + Close -->
            <Grid Grid.Row="0" Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Border x:Name="StatusBadge" CornerRadius="3" Padding="6,2">
                        <TextBlock x:Name="StatusText" FontSize="9"
                                   FontWeight="Bold" Foreground="White" />
                    </Border>
                    <TextBlock x:Name="ClockText" FontSize="10" Margin="6,0,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <Button Grid.Column="1" Content="X"
                        FontSize="10" FontWeight="Bold"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Background="Transparent" BorderThickness="0"
                        Cursor="Hand" Padding="4,0"
                        Click="CloseButton_Click" />
            </Grid>

            <!-- Away Team -->
            <Grid Grid.Row="1" Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border x:Name="AwaySeedBorder" CornerRadius="3" Padding="4,1" Margin="0,0,6,0">
                    <TextBlock x:Name="AwaySeedText" FontSize="9"
                               FontWeight="Bold" Foreground="White" />
                </Border>
                <TextBlock x:Name="AwayTeamText" Grid.Column="1"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock x:Name="AwayScoreText" Grid.Column="2"
                           FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}" />
            </Grid>

            <!-- Home Team -->
            <Grid Grid.Row="2" Margin="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border x:Name="HomeSeedBorder" CornerRadius="3" Padding="4,1" Margin="0,0,6,0">
                    <TextBlock x:Name="HomeSeedText" FontSize="9"
                               FontWeight="Bold" Foreground="White" />
                </Border>
                <TextBlock x:Name="HomeTeamText" Grid.Column="1"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock x:Name="HomeScoreText" Grid.Column="2"
                           FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}" />
            </Grid>
        </Grid>
    </Border>
</Window>
