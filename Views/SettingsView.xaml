<UserControl x:Class="MarchMadnessTracker.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource DarkBgBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="12,8">
        <StackPanel>

            <!-- Favorite Team -->
            <TextBlock Text="FAVORITE TEAM" Style="{StaticResource SectionHeader}" />
            <Border Background="{StaticResource DarkSurfaceBrush}"
                    CornerRadius="8" Padding="14" Margin="0,4,0,12">
                <StackPanel>
                    <TextBlock Text="Select your team to get personalized alerts"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,8" />
                    <ComboBox ItemsSource="{Binding CommonTeams}"
                              SelectedItem="{Binding FavoriteTeam}"
                              Style="{StaticResource DarkComboBox}"
                              IsEditable="True" />
                </StackPanel>
            </Border>

            <!-- Notifications -->
            <TextBlock Text="NOTIFICATIONS" Style="{StaticResource SectionHeader}" />
            <Border Background="{StaticResource DarkSurfaceBrush}"
                    CornerRadius="8" Padding="14" Margin="0,4,0,12">
                <StackPanel>
                    <CheckBox Content="Enable Notifications"
                              IsChecked="{Binding NotificationsEnabled}"
                              Style="{StaticResource DarkCheckBox}"
                              Margin="0,4" />

                    <CheckBox Content="Close Game Alerts (within 5 pts, last 5 min)"
                              IsChecked="{Binding CloseGameAlerts}"
                              Style="{StaticResource DarkCheckBox}"
                              Margin="0,4"
                              IsEnabled="{Binding NotificationsEnabled}" />

                    <CheckBox Content="Upset Alerts"
                              IsChecked="{Binding UpsetAlerts}"
                              Style="{StaticResource DarkCheckBox}"
                              Margin="0,4"
                              IsEnabled="{Binding NotificationsEnabled}" />

                    <CheckBox Content="Favorite Team Game Alerts"
                              IsChecked="{Binding FavoriteTeamAlerts}"
                              Style="{StaticResource DarkCheckBox}"
                              Margin="0,4"
                              IsEnabled="{Binding NotificationsEnabled}" />
                </StackPanel>
            </Border>

            <!-- Display -->
            <TextBlock Text="DISPLAY" Style="{StaticResource SectionHeader}" />
            <Border Background="{StaticResource DarkSurfaceBrush}"
                    CornerRadius="8" Padding="14" Margin="0,4,0,12">
                <StackPanel>
                    <CheckBox Content="Enable Scrolling Ticker Bar"
                              IsChecked="{Binding TickerEnabled}"
                              Style="{StaticResource DarkCheckBox}"
                              Margin="0,4" />

                    <TextBlock Text="Shows a scrolling score ticker at the top of your screen"
                               FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="24,2,0,0" />
                </StackPanel>
            </Border>

            <!-- About -->
            <TextBlock Text="ABOUT" Style="{StaticResource SectionHeader}" />
            <Border Background="{StaticResource DarkSurfaceBrush}"
                    CornerRadius="8" Padding="14" Margin="0,4,0,12">
                <StackPanel>
                    <TextBlock Text="March Madness Tracker v1.0"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Text="NCAA Tournament Score Tracker"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,4,0,0" />
                    <TextBlock Text="Data from ESPN public API"
                               FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,2,0,0" />
                    <TextBlock Text="Polls every 3s (live) / 20s (idle)"
                               FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,2,0,0" />
                </StackPanel>
            </Border>

            <!-- Save Button -->
            <Button Content="Save Settings"
                    Style="{StaticResource ModernButton}"
                    Command="{Binding SaveCommand}"
                    HorizontalAlignment="Stretch"
                    Margin="0,4,0,8"
                    Padding="16,12" />

            <!-- Status Message -->
            <TextBlock Text="{Binding StatusMessage}"
                       FontSize="12"
                       Foreground="{StaticResource LiveGreenBrush}"
                       TextAlignment="Center"
                       Margin="0,4" />

        </StackPanel>
    </ScrollViewer>
</UserControl>
