<Window x:Class="MarchMadnessTracker.Views.TickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Score Ticker"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual"
        Height="32">

    <Border Background="#E6101020" CornerRadius="0"
            BorderBrush="{StaticResource DarkCardBrush}"
            BorderThickness="0,0,0,1">
        <Grid ClipToBounds="True">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Icon -->
            <Border Grid.Column="0" Background="{StaticResource AccentBrush}"
                    Padding="8,0">
                <TextBlock Text="&#x1F3C0; MARCH MADNESS"
                           FontSize="11" FontWeight="Bold"
                           Foreground="White"
                           VerticalAlignment="Center" />
            </Border>

            <!-- Scrolling Content -->
            <Canvas Grid.Column="1" x:Name="TickerCanvas" ClipToBounds="True">
                <TextBlock x:Name="TickerText"
                           Canvas.Top="6"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" />
            </Canvas>

            <!-- Close Button -->
            <Button Grid.Column="2" Content="X"
                    FontSize="10" FontWeight="Bold"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Background="Transparent" BorderThickness="0"
                    Cursor="Hand" Padding="8,0"
                    Click="CloseButton_Click" />
        </Grid>
    </Border>
</Window>
