<UserControl x:Class="MarchMadnessTracker.Views.BracketView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource DarkBgBrush}">

    <Grid Margin="12,8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Round Filter -->
        <ComboBox Grid.Row="0"
                  ItemsSource="{Binding RoundFilters}"
                  SelectedItem="{Binding SelectedRoundFilter}"
                  Style="{StaticResource DarkComboBox}"
                  Margin="0,4,0,8" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Regions}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,0,0,12">
                            <!-- Region Header -->
                            <Border Background="{StaticResource DarkCardBrush}"
                                    CornerRadius="6" Padding="12,8" Margin="0,0,0,6">
                                <TextBlock Text="{Binding RegionName}"
                                           FontSize="16" FontWeight="Bold"
                                           Foreground="{StaticResource AccentBrush}" />
                            </Border>

                            <!-- Games in Region -->
                            <ItemsControl ItemsSource="{Binding Games}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource GameCard}"
                                                BorderBrush="{Binding Game.IsUpset, Converter={StaticResource UpsetToBorder}}"
                                                BorderThickness="1">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <!-- Round & Status -->
                                                <Grid Grid.Row="0" Margin="0,0,0,6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Round}"
                                                               FontSize="10" FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                                    <Border Grid.Column="1"
                                                            Background="{Binding Game.State, Converter={StaticResource StateToColor}}"
                                                            CornerRadius="3" Padding="6,2">
                                                        <TextBlock Text="{Binding Game.State, Converter={StaticResource StateToBadge}}"
                                                                   FontSize="9" FontWeight="Bold"
                                                                   Foreground="White" />
                                                    </Border>
                                                </Grid>

                                                <!-- Away -->
                                                <Grid Grid.Row="1" Margin="0,1">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Background="{Binding Game.AwayColor, Converter={StaticResource HexToColor}}"
                                                            CornerRadius="3" Padding="5,1" Margin="0,0,6,0"
                                                            Visibility="{Binding Game.AwaySeed, Converter={StaticResource SeedToVis}}">
                                                        <TextBlock Text="{Binding Game.AwaySeed}" FontSize="10"
                                                                   FontWeight="Bold" Foreground="White" />
                                                    </Border>
                                                    <TextBlock Grid.Column="1" Text="{Binding Game.AwayAbbreviation}"
                                                               FontSize="13" FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                                    <TextBlock Grid.Column="2" Text="{Binding Game.AwayScore}"
                                                               FontSize="16" FontWeight="Bold"
                                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                                </Grid>

                                                <!-- Home -->
                                                <Grid Grid.Row="2" Margin="0,1">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Background="{Binding Game.HomeColor, Converter={StaticResource HexToColor}}"
                                                            CornerRadius="3" Padding="5,1" Margin="0,0,6,0"
                                                            Visibility="{Binding Game.HomeSeed, Converter={StaticResource SeedToVis}}">
                                                        <TextBlock Text="{Binding Game.HomeSeed}" FontSize="10"
                                                                   FontWeight="Bold" Foreground="White" />
                                                    </Border>
                                                    <TextBlock Grid.Column="1" Text="{Binding Game.HomeAbbreviation}"
                                                               FontSize="13" FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                                    <TextBlock Grid.Column="2" Text="{Binding Game.HomeScore}"
                                                               FontSize="16" FontWeight="Bold"
                                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
