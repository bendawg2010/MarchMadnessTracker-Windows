<Window x:Class="MarchMadnessTracker.Views.NotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Notification"
        Width="320" Height="90"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual">

    <Border Background="#F0161B2E" CornerRadius="10"
            BorderBrush="{StaticResource AccentBrush}"
            BorderThickness="1"
            Padding="14,10">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="&#x1F3C0;"
                       FontSize="24" VerticalAlignment="Center"
                       Margin="0,0,10,0" />

            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock x:Name="TitleText" FontSize="13"
                           FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}" />
                <TextBlock x:Name="MessageText" FontSize="12"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,2,0,0" />
            </StackPanel>

            <Button Grid.Column="2" Content="X"
                    FontSize="10" FontWeight="Bold"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Background="Transparent" BorderThickness="0"
                    Cursor="Hand" Padding="4"
                    VerticalAlignment="Top"
                    Click="CloseButton_Click" />
        </Grid>
    </Border>
</Window>
